# mimir runtime configuration

# Heimdall audio source (Unix socket).
MIMIR_HEIMDALL_SOCKET=/run/heimdall/meeting.sock

# WhisperX model. Try distil-large-v3 first (best speed/quality on CPU per
# ADR 0007); if it fails to load under faster-whisper, set to "medium" or
# "small" and `systemctl restart mimir`.
MIMIR_MODEL=distil-large-v3

# Inference settings.
MIMIR_LANGUAGE=en
MIMIR_COMPUTE_TYPE=int8
MIMIR_BATCH_SIZE=16
MIMIR_WINDOW_SECONDS=5

# Use Silero VAD (open) instead of WhisperX's default pyannote VAD,
# which is HuggingFace-gated and would require a token + EULA we
# explicitly chose not to deal with. See ADR 0007.
MIMIR_VAD_METHOD=silero

# TCP fanout server — bind to LAN so the Mac Studio can connect.
MIMIR_TCP_HOST=0.0.0.0
MIMIR_TCP_PORT=7200

# How many simultaneous CPU threads ctranslate2 may use. Leave a couple
# cores for heimdall and the orchestrator.
OMP_NUM_THREADS=6
